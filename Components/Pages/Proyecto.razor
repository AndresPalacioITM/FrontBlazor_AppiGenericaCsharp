@page "/Proyecto"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Proyecto</PageTitle>

<div class="container mt-4">
    <h3>Proyecto</h3>

    @* ───────── ALERTA DE EXITO O ERROR ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }
    @* ───────── BOTON PARA MOSTRAR FORMULARIO DE CREAR ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Proyecto</button>
    }
    @* ───────── FORMULARIO (CREAR / EDITAR) ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Proyecto" : "Nuevo Proyecto")
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Id</label>
                        <input class="form-control" type="number" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Titulo</label>
                        <input class="form-control" @bind="campoTitulo" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Resumen</label>
                        <input class="form-control" @bind="campoResumen" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Presupuesto</label>
                        <input class="form-control" type="number" step="0.01" @bind="campoPresupuesto" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class ="form-label">Tipo_financiacion</label>
                        <input class="form-control" @bind="campoTipoFinanciacion" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class ="form-label">Tipo_fondos</label>
                        <input class="form-control" @bind="campoTipoFondos" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class ="form-label">Fecha_inicio</label>
                        <input class="form-control" type="date" @bind="campoFechaInicio" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class ="form-label">Fecha_fin</label>
                        <input class="form-control" type="date" @bind="campoFechaFin" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    @* ───────── TABLA DE REGISTROS ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Titulo</th>
                    <th>Resumen</th>
                    <th>Presupuesto</th>
                    <th>Tipo_financiacion</th>
                    <th>Tipo_fondos</th>
                    <th>Fecha_inicio</th>
                    <th>Fecha_fin</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["titulo"]</td>
                        <td>@reg["resumen"]</td>
                        <td>@reg["presupuesto"]</td>
                        <td>@reg["tipo_financiacion"]</td>
                        <td>@reg["tipo_fondos"]</td>
                        <td>@reg["fecha_inicio"]</td>
                        <td>@reg["fecha_fin"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">
                                Editar
                            </button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
     @* ───────── MENSAJE CUANDO NO HAY DATOS ───────── *@
    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla proyecto.</div>
    }
</div>
@code 
{
    // ───────── VARIABLES DE ESTADO ─────────

    // Lista de registros obtenidos de la API
    private List<Dictionary<string, object?>> registros = new();
    // Controla si se muestra el spinner de carga
    private bool cargando = true;
    // Controla si se muestra el formulario
    private bool mostrarFormulario = false;
    // Indica si estamos editando (true) o creando (false)
    private bool editando = false;
    // Mensaje de alerta para el usuario
    private string mensaje = string.Empty;
    // Indica si la ultima operacion fue exitosa (para color de alerta)
    private bool exito = false;
    // Campos del formulario
    private int campoId = 0;
    private string campoTitulo = string.Empty;
    private string campoResumen = string.Empty;
    private double campoPresupuesto = 0;
    private string campoTipoFinanciacion = string.Empty;
    private string campoTipoFondos = string.Empty;
    private DateTime campoFechaInicio = DateTime.MinValue;
    private DateTime campoFechaFin = DateTime.MinValue;

    // ───────── CICLO DE VIDA ─────────

    // Se ejecuta al cargar la pagina por primera vez
    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
    }
     // ───────── METODOS ─────────

    // Obtiene todos los registros de la tabla producto
    private async Task CargarRegistros()
    {
        cargando = true;
        mensaje = string.Empty;
        try
        {
            var resultado = await Api.ListarAsync("proyecto");
            registros = resultado ?? new List<Dictionary<string, object?>>();
             // Si la respuesta es nula, inicializa con lista vacia
        }
        catch (Exception ex)
        {
            registros = new List<Dictionary<string, object?>>();
            mensaje = $"Error al cargar los datos: {ex.Message}";
                exito = false;
        }
        finally
        {
            cargando = false;
        }        
    }
     // Muestra el formulario vacio para crear un nuevo registro
    private void NuevoRegistro()
    {
        editando = false;
        campoId = 0;
        campoTitulo = string.Empty;
        campoResumen = string.Empty;
        campoPresupuesto = 0;
        campoTipoFinanciacion = string.Empty;
        campoTipoFondos = string.Empty;
        campoFechaInicio = DateTime.MinValue;
        campoFechaFin = DateTime.MinValue;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }
    // Llena el formulario con los datos del registro seleccionado
    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = int.TryParse(reg["id"]?.ToString(), out int id) ? id : 0;
        campoTitulo = reg["titulo"]?.ToString() ?? "";
        campoResumen = reg["resumen"]?.ToString() ?? "";
        campoPresupuesto = double.TryParse(reg["presupuesto"]?.ToString(), out double p) ? p : 0;
        campoTipoFinanciacion = reg["tipo_financiacion"]?.ToString() ?? "";
        campoTipoFondos = reg["tipo_fondos"]?.ToString() ?? "";
        campoFechaInicio = DateTime.TryParse(reg["fecha_inicio"]?.ToString(), out DateTime fInicio) ? fInicio : DateTime.MinValue;
        campoFechaFin = DateTime.TryParse(reg["fecha_fin"]?.ToString(), out DateTime fFin) ? fFin : DateTime.MinValue;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }
     // Crea o actualiza un registro segun el modo (editando o creando)
    private async Task GuardarRegistro()
    {
        // Arma el diccionario con los datos del formulario
        var datos = new Dictionary<string, object?>
        {
            ["id"] = campoId,
            ["titulo"] = campoTitulo,
            ["resumen"] = campoResumen,
            ["presupuesto"] = campoPresupuesto,
            ["tipo_financiacion"] = campoTipoFinanciacion,
            ["tipo_fondos"] = campoTipoFondos,
            ["fecha_inicio"] = campoFechaInicio,
            ["fecha_fin"] = campoFechaFin
        };

        if (editando)
        {
            // PUT /api/proyecto/id/{valor}
            // No incluimos el id en los datos porque es la clave
            datos.Remove("id");
            var resultado = await Api.ActualizarAsync("proyecto", "id", campoId.ToString(), datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            // POST /api/proyecto
            var resultado = await Api.CrearAsync("proyecto", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros(); // Recargar la tabla
        }
    }
     // Elimina un registro despues de confirmacion
    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string id = reg["id"]?.ToString() ?? "";

        // DELETE /api/proyecto/id/{valor}
        var resultado = await Api.EliminarAsync("proyecto", "id", id);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
        {
            await CargarRegistros(); // Recargar la tabla
        }
    }

    // Oculta el formulario sin guardar
    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}

